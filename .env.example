# ============================================
# WhatsApp OTP Gateway - Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=production

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=whatsapp_otp_gateway

# API Security
API_KEY=your_super_secret_api_key_here_change_this

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com

# Max WhatsApp Sessions
MAX_SESSIONS=10
